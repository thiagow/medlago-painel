  "conventions": {
    "language": "Portuguese (PT-BR) for domain names",
    "ids": "UUID v4",
    "soft_delete": "deleted_at DateTime? field",
    "timestamps": "created_at, updated_at",
    "naming": "agendamento, paciente, profissional, convenio, atendente",
    "no_redux": true,
    "no_service_layer": true,
    "no_nextauth": true,
    "auth": "JWT custom (jose) + HttpOnly",
    "db_migrations": "SQL manual in prisma/migrations/"
  },
  "security_rules": {
    "passwords": "bcryptjs 12 rounds",
    "tokens": "HttpOnly cookies (never localStorage)",
    "rbac": "Middleware validates + route handler validates",
    "sql": "Prisma (parametrized), never raw queries",
    "cors": "Whitelist, never permissive",
    "pii": "Never log, generic errors",
    "r2": "Presigned URLs (TTL 2h max)",
    "motivo_required": "agendamento cancelado/pendente_confirmacao"
  },
  "do_not_do": [
    "Introduce Redux/Zustand",
    "Create service layer",
    "Use 'prisma migrate dev' auto-generate",
    "Use NextAuth",
    "Expose R2 bucket publicly",
    "Trust client headers for auth",
    "Use hard delete (always soft delete)"
  ],
  "impact": {
    "token_savings_percent": "30-40",
    "consistency": "100%",
    "velocity_increase_percent": "25",
    "onboarding_time_reduction_percent": "70"
  }
}
