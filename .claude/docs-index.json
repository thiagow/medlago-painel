    "database": "PostgreSQL + Prisma 6",
    "auth": "JWT custom (jose) + HttpOnly cookies",
    "storage": "Cloudflare R2 (S3-compatible)",
    "messaging": "Evolution API (2 instances: bot + human)",
    "deployment": "Netlify"
  },
