// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabelas existentes no banco - mapeadas para o schema atual

model Chat {
  id              BigInt    @id @default(autoincrement())
  created_at      DateTime? @db.Timestamptz(6)
  phone           String?
  email           String?
  updated_at      DateTime? @db.Timestamp(6)
  ai_service      String?
  conversation_id String?
  finished        Boolean?  @default(false)
  department_id   BigInt?
  assigned_to     BigInt?
  assigned_at     DateTime? @db.Timestamptz(6)

  // Campos de rastreamento de estado (adicionados para suporte a relatórios)
  // Valores: "ai" | "waiting" | "human" | "finished" | "transferred_external"
  status          String?
  finished_at     DateTime? @db.Timestamptz(6)
  finished_by     BigInt?   // FK implícita para users.id
  tags            ChatTag[]

  @@map("chats")
}

model ChatMessage {
  id              BigInt    @id @default(autoincrement())
  created_at      DateTime? @db.Timestamptz(6)
  phone           String?
  conversation_id String?
  bot_message     String?
  user_message    String?
  media_url       String?
  media_type      String?
  media_name      String?
  active          Boolean?  @default(true)
  sent_by         BigInt?   // FK implícita para users.id — quem enviou a mensagem

  @@map("chat_messages")
}

// Novas tabelas de autenticação

model User {
  id            BigInt    @id @default(autoincrement())
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  name          String
  email         String    @unique
  password_hash String
  role          String    @default("atendente")
  active        Boolean   @default(true)
  must_change_password Boolean @default(false)
  departments   UserDepartment[]

  @@map("users")
}

model Department {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  active      Boolean          @default(true)
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  users       UserDepartment[]

  @@map("departments")
}

model UserDepartment {
  id            BigInt     @id @default(autoincrement())
  user_id       BigInt
  department_id BigInt
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  user          User       @relation(fields: [user_id], references: [id])
  department    Department @relation(fields: [department_id], references: [id])

  @@unique([user_id, department_id])
  @@map("user_departments")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("roles")
}

model ChatTransferLog {
  id                  BigInt   @id @default(autoincrement())
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  chat_id             BigInt
  user_name           String
  reason              String
  summary             String
  transfer_type       String?
  department_id       BigInt?
  external_contact_id BigInt?

  @@map("chat_transfer_logs")
}

model ExternalContact {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(150)
  phone       String    @unique @db.VarChar(50)
  description String?   @db.Text
  active      Boolean   @default(true)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("external_contacts")
}

model Agendamento {
  id                  Int       @id @default(autoincrement())
  created_at          DateTime? @db.Timestamptz(6)
  updated_at          DateTime? @db.Timestamptz(6)
  convenio_id         BigInt?
  profissional_id     BigInt?
  tipo_atendimento_id Int?
  data_atendimento    DateTime? @db.Date
  horario             DateTime? @db.Time(6)
  unidade_id          Int?
  paciente_cpf        String?
  status              String?

  @@map("agendamentos")
}

model Paciente {
  id                 BigInt    @id @default(autoincrement())
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  nome               String?
  cpf                String?   @unique
  data_nascimento    DateTime? @db.Date
  email              String?
  telefone_principal String?

  @@map("pacientes")
}

model Profissional {
  id   BigInt  @id @default(autoincrement())
  nome String?

  @@map("profissionais")
}

model TipoAtendimento {
  id   Int     @id @default(autoincrement())
  nome String?

  @@map("tipos_atendimento")
}

model Convenio {
  id               BigInt    @id @default(autoincrement())
  convenio         String?
  data_criacao     DateTime? @db.Timestamp(6)
  data_atualizacao DateTime? @db.Timestamp(6)

  @@map("convenios")
}

// ─── Módulo de Disparo de Mensagens (Broadcast) ───────────────────────────────

model MessageTemplate {
  id            BigInt      @id @default(autoincrement())
  name          String      @db.VarChar(100)
  body          String?     @db.Text
  image_url     String?     @db.Text
  image_caption String?     @db.VarChar(1024)
  active        Boolean     @default(true)
  created_by    BigInt?
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  broadcasts    Broadcast[]

  @@map("message_templates")
}

model Broadcast {
  id               BigInt               @id @default(autoincrement())
  template_id      BigInt
  template         MessageTemplate      @relation(fields: [template_id], references: [id])
  status           String               @default("draft")
  scheduled_at     DateTime?            @db.Timestamptz(6)
  started_at       DateTime?            @db.Timestamptz(6)
  finished_at      DateTime?            @db.Timestamptz(6)
  total_recipients Int                  @default(0)
  sent_count       Int                  @default(0)
  failed_count     Int                  @default(0)
  created_by       BigInt?
  created_at       DateTime             @default(now()) @db.Timestamptz(6)
  recipients       BroadcastRecipient[]

  @@map("broadcasts")
}

model BroadcastRecipient {
  id           BigInt    @id @default(autoincrement())
  broadcast_id BigInt
  broadcast    Broadcast @relation(fields: [broadcast_id], references: [id])
  patient_id   BigInt
  phone        String
  name         String?
  status       String    @default("pending")
  sent_at      DateTime? @db.Timestamptz(6)
  error        String?

  @@map("broadcast_recipients")
}

model Tag {
  id         BigInt    @id @default(autoincrement())
  name       String    @unique @db.VarChar(50)
  color      String    @default("#6366f1") @db.VarChar(7)
  active     Boolean   @default(true)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  chats      ChatTag[]

  @@map("tags")
}

model ChatTag {
  id         BigInt   @id @default(autoincrement())
  chat_id    BigInt
  tag_id     BigInt
  added_by   BigInt?
  source     String   @default("manual") @db.VarChar(20)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  
  tag        Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  chat       Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)

  @@unique([chat_id, tag_id])
  @@map("chat_tags")
}

// ─── Módulo NPS (Avaliação Pós-Atendimento) ───────────────────────────────────

model NpsConfig {
  id         BigInt   @id @default(autoincrement())
  key        String   @unique @db.VarChar(100)
  value      String   @db.Text
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("nps_config")
}

model NpsResponse {
  id           BigInt    @id @default(autoincrement())
  chat_id      BigInt
  phone        String    @db.VarChar(50)
  agent_name   String?   @db.VarChar(150)
  rating       String?   @db.VarChar(20)   // 'bad' | 'neutral' | 'good' | 'pending'
  nps_score    Int?
  comment      String?   @db.Text
  status       String    @default("pending") @db.VarChar(20) // 'pending' | 'rated' | 'completed'
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  completed_at DateTime? @db.Timestamptz(6)

  @@map("nps_responses")
}
