// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabelas existentes no banco - mapeadas para o schema atual

model Chat {
  id              BigInt    @id @default(autoincrement())
  created_at      DateTime? @db.Timestamptz(6)
  phone           String?
  email           String?
  updated_at      DateTime? @db.Timestamp(6)
  ai_service      String?
  conversation_id String?
  finished        Boolean?  @default(false)
  department_id   BigInt?
  assigned_to     BigInt?
  assigned_at     DateTime? @db.Timestamptz(6)

  // Campos de rastreamento de estado (adicionados para suporte a relatórios)
  // Valores: "ai" | "waiting" | "human" | "finished" | "transferred_external"
  status          String?
  finished_at     DateTime? @db.Timestamptz(6)
  finished_by     BigInt?   // FK implícita para users.id

  @@map("chats")
}

model ChatMessage {
  id              BigInt    @id @default(autoincrement())
  created_at      DateTime? @db.Timestamptz(6)
  phone           String?
  conversation_id String?
  bot_message     String?
  user_message    String?
  media_url       String?
  media_type      String?
  media_name      String?
  active          Boolean?  @default(true)

  @@map("chat_messages")
}

// Novas tabelas de autenticação

model User {
  id            BigInt    @id @default(autoincrement())
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  name          String
  email         String    @unique
  password_hash String
  role          String    @default("atendente")
  active        Boolean   @default(true)
  must_change_password Boolean @default(false)
  departments   UserDepartment[]

  @@map("users")
}

model Department {
  id          BigInt           @id @default(autoincrement())
  name        String           @unique
  description String?
  active      Boolean          @default(true)
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  updated_at  DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  users       UserDepartment[]

  @@map("departments")
}

model UserDepartment {
  id            BigInt     @id @default(autoincrement())
  user_id       BigInt
  department_id BigInt
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  user          User       @relation(fields: [user_id], references: [id])
  department    Department @relation(fields: [department_id], references: [id])

  @@unique([user_id, department_id])
  @@map("user_departments")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("roles")
}

model ChatTransferLog {
  id                  BigInt   @id @default(autoincrement())
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  chat_id             BigInt
  user_name           String
  reason              String
  summary             String
  transfer_type       String?
  department_id       BigInt?
  external_contact_id BigInt?

  @@map("chat_transfer_logs")
}

model ExternalContact {
  id          BigInt    @id @default(autoincrement())
  name        String    @db.VarChar(150)
  phone       String    @unique @db.VarChar(50)
  description String?   @db.Text
  active      Boolean   @default(true)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("external_contacts")
}

model Agendamento {
  id                  Int       @id @default(autoincrement())
  created_at          DateTime? @db.Timestamptz(6)
  updated_at          DateTime? @db.Timestamptz(6)
  convenio_id         BigInt?
  profissional_id     BigInt?
  tipo_atendimento_id Int?
  data_atendimento    DateTime? @db.Date
  horario             DateTime? @db.Time(6)
  unidade_id          Int?
  paciente_cpf        String?
  status              String?

  @@map("agendamentos")
}

model Paciente {
  id                 BigInt    @id @default(autoincrement())
  nome               String?
  cpf                String    @unique
  data_nascimento    DateTime? @db.Date
  email              String?
  telefone_principal String?

  @@map("pacientes")
}

model Profissional {
  id   BigInt  @id @default(autoincrement())
  nome String?

  @@map("profissionais")
}

model TipoAtendimento {
  id   Int     @id @default(autoincrement())
  nome String?

  @@map("tipos_atendimento")
}

model Convenio {
  id               BigInt    @id @default(autoincrement())
  convenio         String?
  data_criacao     DateTime? @db.Timestamp(6)
  data_atualizacao DateTime? @db.Timestamp(6)

  @@map("convenios")
}
